{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "composite": true,
        "tsBuildInfoFile": "./dist/.tsbuildinfo",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["svelte"]
    },
    "include": ["src/**/*.ts", "src/**/*.svelte"],
    "exclude": ["dist", "node_modules", "**/*.test.ts"],
    "references": [{ "path": "../core" }]
}
