{
    "name": "@lyricue/ui",
    "version": "0.1.0",
    "private": true,
    "description": "LyriCue shared Svelte components (KaraokeOutput, SetlistPanel, ModeIndicator, wizards, etc.).",
    "license": "GPL-3.0",
    "type": "module",
    "svelte": "./src/index.ts",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "svelte": "./src/index.ts",
            "types": "./src/index.ts",
            "import": "./src/index.ts"
