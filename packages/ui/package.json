{
    "name": "@lyricue/ui",
    "version": "0.1.0",
    "private": true,
    "description": "LyriCue shared Svelte components (KaraokeOutput, SetlistPanel, ModeIndicator, wizards, etc.).",
    "license": "GPL-3.0",
    "type": "module",
    "svelte": "./src/index.ts",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "svelte": "./src/index.ts",
            "types": "./src/index.ts",
            "import": "./src/index.ts"
        },
        "./*.svelte": "./src/*.svelte"
    },
    "scripts": {
        "build": "svelte-check --tsconfig tsconfig.json",
        "test": "vitest run"
    },
    "dependencies": {
        "@lyricue/core": "*",
        "svelte": "^3.59.2"
    },
    "devDependencies": {
        "@sveltejs/vite-plugin-svelte": "^2.5.3",
        "jsdom": "^24.1.3",
        "svelte-check": "^3.8.6",
        "svelte-preprocess": "^5.1.4",
        "typescript": "^5.3.0",
        "vitest": "^1.2.0"
    }
}
