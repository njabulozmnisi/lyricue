        "svelte-dnd-action": "^0.9.69"
    },
    "devDependencies": {
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "jsdom": "^24.1.3",
        "svelte-check": "^4.6.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.16",
        "vitest": "^4.1.9"
    }
