{
    "name": "@lyricue/core",
    "version": "0.1.0",
    "private": true,
    "description": "LyriCue core: mode-agnostic shared modules (sync engine, audio, STT, storage, sidecar, library, settings, types).",
    "license": "GPL-3.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./types": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/types/index.js"
        },
        "./types/*": {
            "types": "./dist/types/*.d.ts",
            "import": "./dist/types/*.js"
        },
        "./settings": {
            "types": "./dist/settings/index.d.ts",
            "import": "./dist/settings/index.js"
        },
        "./fs": {
            "types": "./dist/fs/index.d.ts",
            "import": "./dist/fs/index.js"
        },
        "./output": {
            "types": "./dist/output/index.d.ts",
            "import": "./dist/output/index.js"
        },
        "./output/test-utils": {
            "types": "./dist/output/test-utils.d.ts",
            "import": "./dist/output/test-utils.js"
        },
        "./diagnostics": {
            "types": "./dist/diagnostics/index.d.ts",
            "import": "./dist/diagnostics/index.js"
        },
        "./timing": {
            "types": "./dist/timing/index.d.ts",
            "import": "./dist/timing/index.js"
        },
        "./sidecar": {
            "types": "./dist/sidecar/index.d.ts",
            "import": "./dist/sidecar/index.js"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "tsc -p tsconfig.json --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "typescript": "^5.3.0",
        "vitest": "^1.2.0"
    }
}
