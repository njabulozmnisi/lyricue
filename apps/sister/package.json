{
    "name": "@lyricue/sister",
    "version": "0.1.0",
    "private": true,
    "description": "LyriCue sister-service Electron app: standalone, drives FreeShow externally via its public APIs.",
    "license": "GPL-3.0",
    "main": "./dist-electron/main.js",
    "type": "module",
    "scripts": {
        "build:main": "tsc -p tsconfig.json",
        "build:preload": "tsc -p tsconfig.preload.json",
        "build:renderer": "vite build --config vite.config.mjs",
        "build": "npm run build:main && npm run build:preload && npm run build:renderer",
        "dev": "echo 'sister-mode dev runner not yet wired (post-MVP polish)' && exit 0",
        "demo:walking-skeleton": "node --experimental-strip-types scripts/demo.ts",
        "test:renderer-perf": "node --experimental-strip-types scripts/karaoke-renderer-perf.ts",
        "test": "vitest run"
    },
    "dependencies": {
        "@lyricue/core": "*",
        "@lyricue/ui": "*",
        "electron": "*",
        "svelte": "^3.59.2"
    },
    "devDependencies": {
        "@sveltejs/vite-plugin-svelte": "^2.5.3",
        "svelte-preprocess": "^5.1.4",
        "typescript": "^5.3.0",
        "vite": "^4.5.0",
        "vitest": "^1.2.0"
    }
}
