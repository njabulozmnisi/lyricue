{
    "name": "@lyricue/fork",
    "version": "0.1.0",
    "private": true,
    "description": "LyriCue fork-mode Electron app: FreeShow fork with LyriCue main-process modules and renderer components integrated in-tree.",
    "license": "GPL-3.0",
    "main": "./dist-electron/electron-main.js",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist-electron/electron-main.d.ts",
            "import": "./dist-electron/electron-main.js"
        },
        "./main": {
            "types": "./dist-electron/main/index.d.ts",
            "import": "./dist-electron/main/index.js"
        },
        "./frontend": {
            "types": "./dist-electron/frontend/index.d.ts",
            "import": "./dist-electron/frontend/index.js"
        },
        "./output/*": {
            "types": "./dist-electron/output/*.d.ts",
            "import": "./dist-electron/output/*.js"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "echo 'fork-mode dev runner not yet wired (post-MVP polish)' && exit 0",
        "demo:walking-skeleton": "node --experimental-strip-types scripts/demo.ts",
        "freeshow:init": "git submodule update --init --recursive freeshow",
        "test": "vitest run"
    },
    "dependencies": {
        "@lyricue/core": "*",
        "@lyricue/ui": "*",
        "electron": "*",
        "svelte": "^3.59.2"
    },
    "devDependencies": {
        "typescript": "^5.3.0",
        "vitest": "^1.2.0"
    }
}
